# AgentZero Business Office — Environment Variables
# Copy this file to .env and fill in your keys.

# Primary API key (used by all agents unless overridden per-agent)
AGENTZERO_API_KEY=your-openrouter-api-key

# Optional: per-provider keys (if agents use different providers)
# ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key

# Optional: channel tokens
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token
# SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
# SLACK_APP_TOKEN=xapp-your-slack-app-token
# DISCORD_BOT_TOKEN=your-discord-bot-token
