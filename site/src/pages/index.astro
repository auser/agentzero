---
import "../styles/global.css";
import "../styles/landing.css";

const base = import.meta.env.BASE_URL;

const commands = [
  { cmd: 'agentzero swarm "summarize this video"', hint: "Goal decomposes into a parallel agent swarm" },
  { cmd: 'agentzero agent -m "hello"', hint: "Run the agent loop" },
  { cmd: 'agentzero agent --stream -m "hello"', hint: "Stream output in real-time" },
  { cmd: "agentzero gateway", hint: "Start the HTTP gateway" },
  { cmd: "agentzero doctor", hint: "Validate environment health" },
];

const features = [
  { title: "Self-Growing", desc: "Every tool created, agent defined, and recipe learned persists encrypted across sessions. The system compounds — week 1 tools accelerate week 4 goals." },
  { title: "Natural Language Tools", desc: "Describe a tool in plain English. The system creates it (shell, HTTP, LLM, or composite), registers it immediately, and persists it forever." },
  { title: "NL Agent Definitions", desc: "Say 'an agent that reviews my PRs daily' — name, system prompt, keywords, tools, and schedule are derived automatically." },
  { title: "Autonomous Swarms", desc: "Give a goal, get a parallel agent DAG. Each node gets only the tools it needs. Sandboxed execution with conflict detection." },
  { title: "Small & Fast", desc: "4.5 MB embedded binary. Millisecond cold starts. Async Tokio runtime with streaming output." },
  { title: "Secure by Default", desc: "Encrypted storage, allowlists, policy gates, audit logging, secret redaction. Fail-closed from day one." },
  { title: "Plugin Sandbox", desc: "WASM plugins run in a bounded sandbox with integrity verification and resource limits." },
  { title: "Multi-Platform Channels", desc: "Telegram, Discord, Slack, and 20+ more. One agent, every platform. Add a channel with a single config line." },
  { title: "37+ LLM Providers", desc: "OpenAI, Anthropic, Google, Ollama, local llama.cpp, and more. Swap providers with a config change — no code required." },
];

const steps = [
  { num: "01", title: "Install", cmd: "cargo install agentzero", desc: "Single binary, no runtime dependencies." },
  { num: "02", title: "Onboard", cmd: "agentzero onboard --interactive", desc: "Interactive wizard writes agentzero.toml." },
  { num: "03", title: "Run Agent", cmd: 'agentzero agent -m "hello"', desc: "Send a message through the agent loop." },
  { num: "04", title: "Start Gateway", cmd: "agentzero gateway", desc: "HTTP/WebSocket gateway with chat, SSE streaming, and pairing." },
];

const metrics = [
  { value: "4.5MB", label: "Embedded Binary" },
  { value: "8", label: "Platform Targets" },
  { value: "4", label: "Client SDKs" },
  { value: "58+", label: "Built-in Tools" },
];

const differentiators = [
  { title: "Self-Growing Runtime", desc: "Tools, agents, and recipes persist encrypted and compound over time. The system you use in month 2 is smarter than month 1 — automatically." },
  { title: "NL Tool Creation", desc: "Describe a missing tool in conversation. The system creates it (shell, HTTP, LLM, composite), makes it available immediately, and persists it across sessions." },
  { title: "Catalog Learning", desc: "Successful tool combos are recorded as recipes. Future goals matching similar patterns get the right tools instantly — no manual configuration." },
  { title: "Single Binary", desc: "One static binary, zero runtime dependencies. 4.5 MB embedded, 18 MB full. Download and run." },
  { title: "Rust Memory Safety", desc: "No GC pauses, no null pointers, no data races. Compile-time guarantees eliminate entire classes of bugs." },
  { title: "Security First", desc: "TOTP approval, secret leak detection, encrypted storage, and tool-level policy gates — all built in." },
  { title: "37+ Providers", desc: "OpenAI, Anthropic, Google, Ollama, local llama.cpp, and 30+ more. Swap providers with a config change." },
  { title: "8 Platform Targets", desc: "Linux (x86/ARM/musl), macOS (Intel/Apple Silicon), Windows. CI-tested on all three OS families." },
  { title: "MCP + A2A", desc: "Model Context Protocol for tool interop. Google A2A for agent-to-agent communication. Standards-first." },
  { title: "Autonomous Swarms", desc: "Give a goal in plain English. The system decomposes it into a parallel agent DAG, each node sandboxed with only the tools it needs." },
  { title: "Client SDKs", desc: "Thin HTTP/WebSocket SDKs for Python, TypeScript, Swift, and Kotlin. Any platform that can make HTTP calls can control AgentZero." },
  { title: "Interactive API Docs", desc: "Every gateway ships Scalar API docs at /docs. Explore and test all 40+ endpoints from the browser." },
];

const pillars = [
  { title: "Self-Growing", items: ["NL tool creation (persists forever)", "NL agent definitions (auto-routed)", "Recipe learning (compounds over time)", "Export/import tools between instances"] },
  { title: "Swap Anything", items: ["Provider trait (37+ LLMs)", "MemoryStore trait (SQLite, Turso)", "Tool trait (58+ built-in + dynamic)", "Channel trait (25+ platforms)"] },
  { title: "Fully Autonomous", items: ["Goal decomposition to agent swarms", "Per-node tool filtering", "Sandboxed parallel execution", "Dead agent recovery", "WASM plugin sandbox"] },
];
---

<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>AgentZero — Self-Growing AI Agent Infrastructure in Rust</title>
    <meta name="description" content="Self-growing AI agent infrastructure in Rust. Describe tools and agents in plain English — the system assembles, remembers, and gets smarter over time. Encrypted persistence, 58+ built-in tools, WASM plugins, multi-agent swarms. Any OS, any platform." />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body class="az-page">
    <nav class="az-nav">
      <div class="az-nav-inner">
        <a href={base} class="az-logo">AgentZero</a>
        <button class="az-hamburger" aria-label="Toggle menu" aria-expanded="false">
          <span></span>
          <span></span>
          <span></span>
        </button>
        <div class="az-nav-links">
          <a href="#features">Features</a>
          <a href="#why">Why AgentZero</a>
          <a href="#how-it-works">How It Works</a>
          <a href="#architecture">Architecture</a>
          <a href={`${base}overview/`} class="az-nav-docs">Docs</a>
          <a href="https://github.com/auser/agentzero" class="az-nav-gh" target="_blank" rel="noopener">GitHub</a>
        </div>
      </div>
    </nav>

    <script>
      const hamburger = document.querySelector('.az-hamburger');
      const navLinks = document.querySelector('.az-nav-links');
      if (hamburger && navLinks) {
        hamburger.addEventListener('click', () => {
          const expanded = hamburger.getAttribute('aria-expanded') === 'true';
          hamburger.setAttribute('aria-expanded', String(!expanded));
          hamburger.classList.toggle('az-hamburger--open');
          navLinks.classList.toggle('az-nav-links--open');
        });
        navLinks.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            hamburger.setAttribute('aria-expanded', 'false');
            hamburger.classList.remove('az-hamburger--open');
            navLinks.classList.remove('az-nav-links--open');
          });
        });
      }
    </script>

    <main>
      <!-- Hero -->
      <section class="az-hero">
        <div class="az-hero-inner">
          <div class="az-hero-text">
            <p class="az-eyebrow">SELF-GROWING AI AGENT INFRASTRUCTURE</p>
            <h1>Describe it. It builds itself.<br /><span class="az-accent">And remembers.</span></h1>
            <p class="az-lead">Define agents and tools in plain English. The system self-assembles, persists everything, and gets smarter over time.</p>
            <p class="az-sub">Say "summarize this video" and it decomposes the goal, creates missing tools, executes in parallel, and remembers what worked. Next time, it's faster. All encrypted, all Rust. 🦀</p>
            <div class="az-hero-actions">
              <a href={`${base}overview/`} class="az-btn az-btn-primary">Read the docs</a>
              <a href="https://github.com/auser/agentzero" class="az-btn az-btn-secondary" target="_blank" rel="noopener">GitHub</a>
            </div>
          </div>
          <aside class="az-command-lane">
            <h2>Runtime commands</h2>
            <ul>
              {commands.map((c) => (
                <li>
                  <code>{c.cmd}</code>
                  <span>{c.hint}</span>
                </li>
              ))}
            </ul>
          </aside>
        </div>
      </section>

      <!-- Metrics -->
      <section class="az-metrics">
        {metrics.map((m) => (
          <article>
            <p class="az-metric-value">{m.value}</p>
            <p class="az-metric-label">{m.label}</p>
          </article>
        ))}
      </section>

      <!-- Features -->
      <section id="features" class="az-features">
        <h2>Built for production</h2>
        <div class="az-features-grid">
          {features.map((f) => (
            <article>
              <h3>{f.title}</h3>
              <p>{f.desc}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- Why AgentZero -->
      <section id="why" class="az-why">
        <h2>Why AgentZero</h2>
        <p class="az-why-lead">Everything you need to run AI agents in production — nothing you don't.</p>
        <div class="az-why-grid">
          {differentiators.map((d) => (
            <article>
              <h3>{d.title}</h3>
              <p>{d.desc}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- Install -->
      <section class="az-install">
        <h2>Install in seconds</h2>
        <p class="az-install-lead">One command. One binary. No dependencies.</p>
        <div class="az-install-terminal">
          <div class="az-terminal-bar">
            <span class="az-terminal-dot"></span>
            <span class="az-terminal-dot"></span>
            <span class="az-terminal-dot"></span>
          </div>
          <pre><code><span class="az-prompt">$</span> curl -fsSL https://raw.githubusercontent.com/auser/agentzero/main/scripts/install.sh | bash</code></pre>
        </div>
        <p class="az-install-alt">
          Or install with Cargo: <code>cargo install agentzero</code>
        </p>
      </section>

      <!-- How It Works -->
      <section id="how-it-works" class="az-steps">
        <h2>How it works</h2>
        <div class="az-steps-grid">
          {steps.map((s) => (
            <article>
              <span class="az-step-num">{s.num}</span>
              <h3>{s.title}</h3>
              <code>{s.cmd}</code>
              <p>{s.desc}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- Architecture -->
      <section id="architecture" class="az-arch">
        <h2>Modular architecture</h2>
        <div class="az-arch-grid">
          {pillars.map((p) => (
            <article>
              <h3>{p.title}</h3>
              <ul>
                {p.items.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          ))}
        </div>
      </section>

      <!-- CTA -->
      <section class="az-cta">
        <h2>Deploy anywhere. Swap anything. 🦀</h2>
        <p>Fast, small, extensible, and fully autonomous. Secure by design. Configured in conversation.</p>
        <div class="az-cta-actions">
          <a href={`${base}overview/`} class="az-btn az-btn-primary">Get started</a>
          <a href="https://github.com/auser/agentzero" class="az-btn az-btn-secondary" target="_blank" rel="noopener">View on GitHub</a>
        </div>
      </section>
    </main>

    <footer class="az-footer">
      <div class="az-footer-inner">
        <p class="az-footer-brand">AgentZero</p>
        <div class="az-footer-links">
          <a href={`${base}overview/`}>Documentation</a>
          <a href="https://github.com/auser/agentzero" target="_blank" rel="noopener">GitHub</a>
        </div>
        <p class="az-footer-copy">&copy; 2026 AgentZero contributors</p>
      </div>
    </footer>
  </body>
</html>
