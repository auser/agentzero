# AgentZero — Environment Variables
# Copy this file to .env and fill in your keys.
# .env files are gitignored and never committed.

# Primary LLM provider API key
# AGENTZERO_API_KEY=your-api-key

# Gateway bearer token (auto-generated if not set)
# AGENTZERO_GATEWAY_BEARER_TOKEN=your-bearer-token

# Optional: search provider keys
# BRAVE_API_KEY=your-brave-search-api-key

# Optional: notification keys
# PUSHOVER_TOKEN=your-pushover-token
# PUSHOVER_USER=your-pushover-user

# Optional: integration keys
# COMPOSIO_API_KEY=your-composio-api-key

# Optional: channel tokens
# TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Optional: local LLM URL (for testing)
# LOCAL_LLM_URL=http://localhost:11434/v1
