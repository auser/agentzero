#!/bin/bash
#
# Pre-commit hook for agentzero
# - Auto-fixes formatting with cargo fmt --all and re-stages the changes
# - Auto-fixes clippy warnings with cargo clippy --fix --allow-staged and re-stages
# - Errors if any clippy warnings remain after auto-fix (require manual resolution)
#
# Full test suite runs in CI and can be triggered locally with:
#   just test
#
# To install this hook, run:
#   git config core.hooksPath .githooks
# Or copy this file to .git/hooks/pre-commit
#

set -e

if command -v sccache >/dev/null 2>&1; then
    export RUSTC_WRAPPER=sccache
    export SCCACHE_CACHE_SIZE="${SCCACHE_CACHE_SIZE:-10G}"
    echo "Using sccache for compilation caching"
fi

echo "Running pre-commit checks..."

# ── Formatting ────────────────────────────────────────────────────────────────
echo "Fixing code formatting..."
cargo fmt --all 2>/dev/null
# Re-stage any files reformatted by cargo fmt
git add -u
echo "Formatting OK"
echo ""

# ── Determine changed crates ──────────────────────────────────────────────────
CHANGED_CRATES=$(git diff --cached --name-only --diff-filter=ACMR \
    | sed -n 's|^crates/\([^/]*\)/.*|\1|p' \
    | sort -u)

if git diff --cached --name-only --diff-filter=ACMR | grep -q '^bin/'; then
    CHANGED_CRATES=$(printf '%s\nagentzero' "$CHANGED_CRATES")
fi

WORKSPACE_MANIFEST_CHANGED=false
if git diff --cached --name-only --diff-filter=ACMR | grep -q '^Cargo\.toml$'; then
    WORKSPACE_MANIFEST_CHANGED=true
fi

if [ -z "$CHANGED_CRATES" ] && [ "$WORKSPACE_MANIFEST_CHANGED" = false ]; then
    echo "No crate changes staged — skipping clippy"
    echo "All pre-commit checks passed!"
    exit 0
fi

# ── Build clippy scope ────────────────────────────────────────────────────────
if [ "$WORKSPACE_MANIFEST_CHANGED" = true ] && [ -z "$CHANGED_CRATES" ]; then
    CLIPPY_SCOPE="--workspace"
    SCOPE_DESC="workspace"
else
    CLIPPY_SCOPE=""
    for crate in $CHANGED_CRATES; do
        CLIPPY_SCOPE="$CLIPPY_SCOPE -p $crate"
    done
    SCOPE_DESC=$(echo "$CHANGED_CRATES" | tr '\n' ' ')
fi

# ── Clippy auto-fix ───────────────────────────────────────────────────────────
echo "Auto-fixing clippy warnings in: $SCOPE_DESC..."
# shellcheck disable=SC2086
cargo clippy --fix --allow-dirty --allow-staged $CLIPPY_SCOPE -- -D warnings 2>/dev/null || true
git add -u

# ── Clippy verify + build test binaries (single cargo invocation) ─────────────
# --all-targets compiles lib + bin + test + bench targets, so nextest below
# only needs to *run* pre-built binaries — no recompilation.
echo "Verifying clippy (also pre-builds test binaries)..."
# shellcheck disable=SC2086
if ! cargo clippy --all-targets $CLIPPY_SCOPE -- -D warnings; then
    echo ""
    echo "Clippy check failed — some warnings require manual fixes."
    echo "   Run: cargo clippy --fix --allow-dirty -- -D warnings"
    exit 1
fi
echo "Clippy passed"

# ── Tests (binaries pre-built above, just run them) ───────────────────────────
SKIP_CRATES="agentzero-ffi agentzero-plugin-sdk"
TEST_SCOPE=""
for crate in $CHANGED_CRATES; do
    skip=false
    for s in $SKIP_CRATES; do
        if [ "$crate" = "$s" ]; then skip=true; break; fi
    done
    if [ "$skip" = false ]; then
        TEST_SCOPE="$TEST_SCOPE -p $crate"
    fi
done

if [ -n "$TEST_SCOPE" ] || [ "$WORKSPACE_MANIFEST_CHANGED" = true ]; then
    if [ "$WORKSPACE_MANIFEST_CHANGED" = true ] && [ -z "$TEST_SCOPE" ]; then
        TEST_SCOPE="--workspace --exclude agentzero-ffi --exclude agentzero-plugin-sdk"
    fi
    TEST_KINDS="--lib --bins"
    echo "Running unit tests only (pre-built)..."
    if command -v cargo-nextest &>/dev/null; then
        # shellcheck disable=SC2086
        if ! cargo nextest run --no-fail-fast --no-tests=pass $TEST_KINDS $TEST_SCOPE; then
            echo ""
            echo "Tests failed."
            exit 1
        fi
    else
        # shellcheck disable=SC2086
        if ! cargo test $TEST_KINDS $TEST_SCOPE; then
            echo ""
            echo "Tests failed."
            exit 1
        fi
    fi
    echo "Tests passed"
else
    echo "No testable crates changed — skipping tests"
fi

echo "All pre-commit checks passed!"
