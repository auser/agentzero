#!/bin/bash
#
# Pre-commit hook for agentzero
#
# Fast by default (~5-15s for typical changes):
#   - Auto-fixes formatting with cargo fmt and re-stages
#   - Runs cargo check on changed crates (type errors only, no lints)
#
# Set PRECOMMIT_FULL=1 for the full gate (clippy + unit tests):
#   PRECOMMIT_FULL=1 git commit -m "..."
#
# Full test suite runs in CI and locally with:
#   just test          # all tests
#   just test-unit     # lib-only (fast)
#   just ci            # fmt + clippy + test
#
# To install: git config core.hooksPath .githooks

set -e

if command -v sccache >/dev/null 2>&1; then
    export RUSTC_WRAPPER=sccache
fi

echo "Running pre-commit checks..."

# ── Formatting ────────────────────────────────────────────────────────────────
echo "Fixing code formatting..."
cargo fmt --all 2>/dev/null
git add -u
echo "Formatting OK"

# ── Determine changed crates ─────────────────────────────────────────────────
CHANGED_CRATES=$(git diff --cached --name-only --diff-filter=ACMR \
    | sed -n 's|^crates/\([^/]*\)/.*|\1|p' \
    | sort -u)

if git diff --cached --name-only --diff-filter=ACMR | grep -q '^bin/'; then
    CHANGED_CRATES=$(printf '%s\nagentzero' "$CHANGED_CRATES")
fi

WORKSPACE_MANIFEST_CHANGED=false
if git diff --cached --name-only --diff-filter=ACMR | grep -q '^Cargo\.toml$'; then
    WORKSPACE_MANIFEST_CHANGED=true
fi

if [ -z "$CHANGED_CRATES" ] && [ "$WORKSPACE_MANIFEST_CHANGED" = false ]; then
    echo "No crate changes staged — skipping compilation checks"
    echo "Pre-commit OK"
    exit 0
fi

# ── Build scope ──────────────────────────────────────────────────────────────
if [ "$WORKSPACE_MANIFEST_CHANGED" = true ] && [ -z "$CHANGED_CRATES" ]; then
    CHECK_SCOPE="--workspace"
    SCOPE_DESC="workspace"
else
    CHECK_SCOPE=""
    for crate in $CHANGED_CRATES; do
        CHECK_SCOPE="$CHECK_SCOPE -p $crate"
    done
    SCOPE_DESC=$(echo "$CHANGED_CRATES" | tr '\n' ' ')
fi

# ── Fast path (default): cargo check only ────────────────────────────────────
if [ "${PRECOMMIT_FULL:-0}" != "1" ]; then
    echo "Checking compilation for: $SCOPE_DESC..."
    # shellcheck disable=SC2086
    if ! cargo check $CHECK_SCOPE 2>&1 | tail -5; then
        echo ""
        echo "Compilation failed. Fix errors before committing."
        exit 1
    fi
    echo "Pre-commit OK (fast mode — run 'just ci' for full checks)"
    exit 0
fi

# ── Full path (PRECOMMIT_FULL=1): clippy + tests ────────────────────────────
echo "Running FULL pre-commit checks for: $SCOPE_DESC..."

# Clippy: single pass with auto-fix, then verify
# shellcheck disable=SC2086
cargo clippy --fix --allow-dirty --allow-staged $CHECK_SCOPE -- -D warnings 2>/dev/null || true
git add -u

# shellcheck disable=SC2086
if ! cargo clippy $CHECK_SCOPE -- -D warnings; then
    echo ""
    echo "Clippy check failed — some warnings require manual fixes."
    exit 1
fi
echo "Clippy passed"

# Tests: lib + bins only, scoped to changed crates
SKIP_CRATES="agentzero-ffi agentzero-plugin-sdk"
TEST_SCOPE=""
for crate in $CHANGED_CRATES; do
    skip=false
    for s in $SKIP_CRATES; do
        if [ "$crate" = "$s" ]; then skip=true; break; fi
    done
    if [ "$skip" = false ]; then
        TEST_SCOPE="$TEST_SCOPE -p $crate"
    fi
done

if [ -n "$TEST_SCOPE" ] || [ "$WORKSPACE_MANIFEST_CHANGED" = true ]; then
    if [ "$WORKSPACE_MANIFEST_CHANGED" = true ] && [ -z "$TEST_SCOPE" ]; then
        TEST_SCOPE="--workspace --exclude agentzero-ffi --exclude agentzero-plugin-sdk"
    fi
    TEST_KINDS="--lib --bins"
    echo "Running unit tests..."
    if command -v cargo-nextest &>/dev/null; then
        # shellcheck disable=SC2086
        cargo nextest run --no-fail-fast --no-tests=pass $TEST_KINDS $TEST_SCOPE
    else
        # shellcheck disable=SC2086
        cargo test $TEST_KINDS $TEST_SCOPE
    fi
    echo "Tests passed"
else
    echo "No testable crates changed — skipping tests"
fi

echo "All pre-commit checks passed!"
